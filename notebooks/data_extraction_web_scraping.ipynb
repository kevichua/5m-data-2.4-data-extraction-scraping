    "import requests\n",
    "import time\n",
    "import pandas as pd\n",
    "from bs4 import BeautifulSoup\n",
    "\n",
    "def parse_hockey_page(html_text):\n",
    "    \"\"\"\n",
    "    Parse NHL hockey stats from a single page HTML.\n",
    "    Returns a list of dictionaries, each representing one team's stats for a year.\n",
    "    \"\"\"\n",
    "    soup = BeautifulSoup(html_text, 'html.parser')\n",
    "    teams_data = []\n",
    "    \n",
    "    # Find the table containing hockey stats\n",
    "    table = soup.find('table', class_='table')\n",
    "    \n",
    "    if not table:\n",
    "        return teams_data\n",
    "    \n",
    "    # Get all rows in the table body\n",
    "    rows = table.find('tbody').find_all('tr') if table.find('tbody') else table.find_all('tr')[1:]\n",
    "    \n",
    "    for row in rows:\n",
    "        cols = row.find_all('td')\n",
    "        if len(cols) >= 6:  # Ensure we have enough columns\n",
    "            team_dict = {\n",
    "                'Team': cols[0].text.strip(),\n",
    "                'Year': cols[1].text.strip(),\n",
    "                'Wins': cols[2].text.strip(),\n",
    "                'Losses': cols[3].text.strip(),\n",
    "                'OT_Losses': cols[4].text.strip(),\n",
    "                'Win_Percentage': cols[5].text.strip(),\n",
    "                'Goals_For': cols[6].text.strip() if len(cols) > 6 else '',\n",
    "                'Goals_Against': cols[7].text.strip() if len(cols) > 7 else ''\n",
    "            }\n",
    "            teams_data.append(team_dict)\n",
    "    \n",
    "    return teams_data\n",
    "\n",
    "# Step 1-4: Loop through pages 1-24 and collect all data\n",
    "all_rows = []\n",
    "\n",
    "print(\"Starting to scrape 24 pages of NHL hockey stats...\")\n",
    "print(\"-\" * 50)\n",
    "\n",
    "for page in range(1, 25):\n",
    "    url = f\"https://www.scrapethissite.com/pages/forms/?page_num={page}\"\n",
    "    \n",
    "    try:\n",
    "        # Make the request with a user-agent to be respectful\n",
    "        headers = {\n",
    "            'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36'\n",
    "        }\n",
    "        response = requests.get(url, headers=headers)\n",
    "        response.raise_for_status()  # Check for HTTP errors\n",
    "        \n",
    "        # Parse the page and extend our list\n",
    "        page_data = parse_hockey_page(response.text)\n",
    "        all_rows.extend(page_data)\n",
    "        \n",
    "        print(f\"Page {page:2d}: Scraped {len(page_data):2d} team records (Total so far: {len(all_rows):4d})\")\n",
    "        \n",
    "        # Be polite to the server\n",
    "        time.sleep(1)\n",
    "        \n",
    "    except requests.RequestException as e:\n",
    "        print(f\"Error on page {page}: {e}\")\n",
    "        continue\n",
    "\n",
    "print(\"-\" * 50)\n",
    "print(f\"Completed! Total team records scraped: {len(all_rows)}\")\n",
    "print()\n",
    "\n",
    "# Step 5: Convert to DataFrame\n",
    "hockey_stats = pd.DataFrame(all_rows)\n",
    "\n",
    "# Display first few rows to verify\n",
    "print(\"First 5 rows of the DataFrame:\")\n",
    "print(hockey_stats.head())\n",
    "print()\n",
    "\n",
    "# Step 6: Find the team with the most total Wins across all years\n",
    "# Convert Wins column to numeric\n",
    "hockey_stats['Wins'] = pd.to_numeric(hockey_stats['Wins'], errors='coerce')\n",
    "\n",
    "# Group by team and sum wins\n",
    "team_wins = hockey_stats.groupby('Team')['Wins'].sum()\n",
    "\n",
    "# Find the team with maximum wins\n",
    "most_wins_team = team_wins.idxmax()\n",
    "most_wins_total = team_wins.max()\n",
    "\n",
    "print(\"=\" * 50)\n",
    "print(f\"🏆 Team with the most total wins across all years: {most_wins_team}\")\n",
    "print(f\"📊 Total wins: {most_wins_total}\")\n",
    "print(\"=\" * 50)\n",
    "\n",
    "# Bonus: Show top 5 teams\n",
    "print(\"\\nTop 5 teams by total wins:\")\n",
    "print(team_wins.sort_values(ascending=False).head())\n",
    "\n",
    "# Bonus: Show which year had the most wins for the top team\n",
    "top_team_data = hockey_stats[hockey_stats['Team'] == most_wins_team]\n",
    "print(f\"\\n{most_wins_team} wins by year:\")\n",
    "print(top_team_data[['Year', 'Wins']].sort_values('Year'))"
   ]
