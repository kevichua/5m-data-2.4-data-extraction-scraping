    "# Sample solution for Exercise 3 — this will be the basis for your code, but feel free to modify it as you see fit!\n",
    "\n",
    "all_rows = []\n",
    "\n",
    "for page in range(1, 25):\n",
    "    url = f\"https://www.scrapethissite.com/pages/forms/?page_num={page}\"\n",
    "    r = requests.get(url)\n",
    "    parsed = parse_hockey_page(r.text)\n",
    "    all_rows.extend(parsed)\n",
    "    print(f\"Page {page}: status {r.status_code}, rows this page: {len(parsed)}, total: {len(all_rows)}\")\n",
    "    time.sleep(1)\n",
    "\n",
    "# Convert to DataFrame\n",
    "hockey_stats = pd.DataFrame(all_rows)\n",
    "print(\"\\nActual columns:\", hockey_stats.columns.tolist())\n",
    "print(hockey_stats.head())\n",
    "\n",
    "# Step 6: Find the team with the most total Wins\n",
    "hockey_stats['Wins'] = pd.to_numeric(hockey_stats['Wins'], errors='coerce')\n",
    "top_team = hockey_stats.groupby('Team Name')['Wins'].sum().idxmax()\n",
    "top_wins  = hockey_stats.groupby('Team Name')['Wins'].sum().max()\n",
    "\n",
    "print(f\"\\n🏆 Team with most total Wins: {top_team} ({int(top_wins)} wins)\")"
   ]
