   "source": [
    "# Sample solution for Exercise 1\n",
    "\n",
    "import requests\n",
    "import os\n",
    "import time\n",
    "import pandas as pd\n",
    "import sqlalchemy as sqla\n",
    "from dotenv import load_dotenv\n",
    "\n",
    "load_dotenv()\n",
    "access_token = os.getenv('GITHUB_TOKEN')\n",
    "\n",
    "# Reuse the same headers pattern from the worked example\n",
    "headers = {\n",
    "    \"Accept\": \"application/vnd.github+json\",\n",
    "    \"Authorization\": f\"Bearer {access_token}\",\n",
    "    \"X-GitHub-Api-Version\": \"2022-11-28\"\n",
    "}\n",
    "\n",
    "# ── Step 1: Call the stats/contributors endpoint ─────────────────────────────\n",
    "# ⚠️ GitHub returns 202 if stats aren't ready yet — retry until we get 200\n",
    "url = \"https://api.github.com/repos/pandas-dev/pandas/stats/contributors\"\n",
    "\n",
    "while True:\n",
    "    response = requests.get(url, headers=headers)\n",
    "    print(f\"Status: {response.status_code}\")\n",
    "    if response.status_code == 200:\n",
    "        break\n",
    "    elif response.status_code == 202:\n",
    "        print(\"⏳ GitHub is computing stats... waiting 10 seconds\")\n",
    "        time.sleep(10)\n",
    "    else:\n",
    "        print(f\"❌ Unexpected status: {response.status_code}\")\n",
    "        break\n",
    "\n",
    "# ── Step 2: Extract login and total from each item ───────────────────────────\n",
    "# Each item structure: { 'total': 1234, 'author': { 'login': 'jreback' }, 'weeks': [...] }\n",
    "data = response.json()\n",
    "\n",
    "records = [\n",
    "    {\n",
    "        \"login\": item[\"author\"][\"login\"],      # nested: item → author → login\n",
    "        \"total_commits\": item[\"total\"]         # top-level: item → total\n",
    "    }\n",
    "    for item in data\n",
    "]\n",
    "\n",
    "# ── Step 3: Build the DataFrame ───────────────────────────────────────────────\n",
    "contributors = pd.DataFrame(records)\n",
    "print(f\"\\nTotal contributors: {len(contributors)}\")\n",
    "print(contributors.head())\n",
    "\n",
    "# ── Step 4: Find the top contributor ─────────────────────────────────────────\n",
    "top = contributors.sort_values(\"total_commits\", ascending=False).head(1)\n",
    "print(f\"\\n🏆 Top contributor: {top['login'].values[0]} with {top['total_commits'].values[0]} commits\")\n",
    "\n",
    "# ── Step 5: Save to DuckDB as pandas_contributors ────────────────────────────\n",
    "# Note: engine was disposed after the releases save — recreate it (per Hint 4)\n",
    "parent_dir = os.path.abspath(os.path.pardir)\n",
    "engine2 = sqla.create_engine(f'duckdb:///{parent_dir}/output/unit-2-4.db')\n",
    "\n",
    "try:\n",
    "    contributors.to_sql(\"pandas_contributors\", engine2, if_exists='replace', index=False)\n",
    "    print(\"✅ Saved pandas_contributors to DuckDB\")\n",
    "except Exception as e:\n",
    "    print(f\"❌ Error: {e}\")\n",
    "finally:\n",
    "    engine2.dispose()\n",
    "    print(\"Connection closed.\")"
   ]
  },
