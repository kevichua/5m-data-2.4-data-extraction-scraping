    "# Sample solution for Exercise 2\n",
    "\n",
    "import requests\n",
    "import os\n",
    "import pandas as pd\n",
    "from dotenv import load_dotenv\n",
    "\n",
    "# Ensure token is loaded\n",
    "load_dotenv()\n",
    "access_token = os.getenv('GITHUB_TOKEN')\n",
    "\n",
    "# 1 & 2. Write the GraphQL query for issues\n",
    "query = \"\"\"\n",
    "query {\n",
    "  repository(owner: \"pandas-dev\", name: \"pandas\") {\n",
    "    issues(first: 50, states: OPEN) {\n",
    "      edges {\n",
    "        node {\n",
    "          title\n",
    "          createdAt\n",
    "          author {\n",
    "            login\n",
    "          }\n",
    "        }\n",
    "      }\n",
    "    }\n",
    "  }\n",
    "}\n",
    "\"\"\"\n",
    "\n",
    "# 3. Send it via requests.post\n",
    "url = \"https://api.github.com/graphql\"\n",
    "headers = {\n",
    "    \"Authorization\": f\"Bearer {access_token}\"\n",
    "}\n",
    "\n",
    "response = requests.post(url, headers=headers, json={\"query\": query})\n",
    "\n",
    "if response.status_code == 200:\n",
    "    data = response.json()\n",
    "    \n",
    "    # 4. Navigate the response and build the DataFrame\n",
    "    edges = data['data']['repository']['issues']['edges']\n",
    "    \n",
    "    records = []\n",
    "    for edge in edges:\n",
    "        node = edge['node']\n",
    "        # Handle the case where author might be None (deleted accounts)\n",
    "        author_login = node['author']['login'] if node['author'] else None\n",
    "        \n",
    "        records.append({\n",
    "            \"title\": node['title'],\n",
    "            \"created_at\": node['createdAt'],\n",
    "            \"author\": author_login\n",
    "        })\n",
    "        \n",
    "    issues_df = pd.DataFrame(records)\n",
    "    \n",
    "    print(f\"✅ Successfully fetched {len(issues_df)} issues!\")\n",
    "    display(issues_df.head())\n",
    "    \n",
    "else:\n",
    "    print(f\"❌ Query failed with status code {response.status_code}\")\n",
    "    print(response.text)"
   ]
  },
