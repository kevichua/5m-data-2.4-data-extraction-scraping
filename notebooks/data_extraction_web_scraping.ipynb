    "import time\n",
    "\n",
    "contributors_url = \"https://api.github.com/repos/pandas-dev/pandas/stats/contributors\"\n",
    "headers = {\n",
    "    \"Accept\": \"application/vnd.github+json\",\n",
    "    \"Authorization\": f\"Bearer {access_token}\",\n",
    "    \"X-GitHub-Api-Version\": \"2022-11-28\"\n",
    "}\n",
    "\n",
    "contributors_response = requests.get(contributors_url, headers=headers)\n",
    "\n",
    "# GitHub may return 202 while it prepares the contributor stats.\n",
    "if contributors_response.status_code == 202:\n",
    "    print(\"Stats are being generated. Waiting 10 seconds before retrying...\")\n",
    "    time.sleep(10)\n",
    "    contributors_response = requests.get(contributors_url, headers=headers)\n",
    "\n",
    "print(\"Status:\", contributors_response.status_code)\n",
    "\n",
    "contributors_data = contributors_response.json()\n",
    "\n",
    "contributors = pd.DataFrame([\n",
    "    {\n",
    "        \"login\": item[\"author\"][\"login\"],\n",
    "        \"total_commits\": item[\"total\"]\n",
    "    }\n",
    "    for item in contributors_data\n",
    "    if item.get(\"author\") and item[\"author\"].get(\"login\")\n",
    "])\n",
    "\n",
    "top_contributor = contributors.sort_values(\"total_commits\", ascending=False).head(1)\n",
    "print(\"Top contributor:\")\n",
    "print(top_contributor)\n",
    "\n",
    "engine2 = sqla.create_engine(f'duckdb:///{parent_dir}/output/unit-2-4.db')\n",
    "contributors.to_sql(\"pandas_contributors\", engine2, if_exists='replace', index=False)\n",
    "engine2.dispose()\n",
    "print(\"Saved pandas_contributors to DuckDB\")\n",
    "\n",
    "contributors.head()\n"
   ]
  },
