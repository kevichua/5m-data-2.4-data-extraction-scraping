      "text/plain": [
       "<h3 class=\"country-name\">\n",
       "<i class=\"flag-icon flag-icon-ad\"></i>\n",
       "                            Andorra\n",
       "                        </h3>"
      ]
     },
     "execution_count": 66,
     "metadata": {},
     "output_type": "execute_result"
    }
   ],
   "source": [
    "# Find all country name elements — these are <h3> tags with class \"country-name\"\n",
    "country_name_elements = soup.find_all('h3', 'country-name')  # 👈 tag name first, then class name\n",
    "print(f\"Found {len(country_name_elements)} country names\")\n",
    "country_name_elements[0]   # 👈 see the raw tag — useful to confirm we found the right element"
   ]
