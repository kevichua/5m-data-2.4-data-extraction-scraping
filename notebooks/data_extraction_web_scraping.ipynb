    "import requests\n",
    "import os\n",
    "from dotenv import load_dotenv\n",
    "import pandas as pd\n",
    "\n",
    "load_dotenv()\n",
    "access_token = os.getenv('GITHUB_TOKEN')\n",
    "\n",
    "# GraphQL endpoint\n",
    "url = \"https://api.github.com/graphql\"\n",
    "\n",
    "# Headers\n",
    "headers = {\n",
    "    \"Authorization\": f\"Bearer {TOKEN}\"\n",
    "}\n",
    "\n",
    "# GraphQL query\n",
    "query = \"\"\"\n",
    "{\n",
    "  repository(owner: \"pandas-dev\", name: \"pandas\") {\n",
    "    issues(first: 50, states: OPEN) {\n",
    "      edges {\n",
    "        node {\n",
    "          title\n",
    "          createdAt\n",
    "          author {\n",
    "            login\n",
    "          }\n",
    "        }\n",
    "      }\n",
    "    }\n",
    "  }\n",
    "}\n",
    "\"\"\"\n",
    "\n",
    "# Send request\n",
    "response = requests.post(\n",
    "    url,\n",
    "    json={\"query\": query},\n",
    "    headers=headers\n",
    ")\n",
    "\n",
    "# Convert response to JSON\n",
    "data = response.json()\n",
    "\n",
    "# Navigate response\n",
    "edges = data['data']['repository']['issues']['edges']\n",
    "\n",
    "# Build records safely\n",
    "records = []\n",
    "\n",
    "for edge in edges:\n",
    "    node = edge['node']\n",
    "\n",
    "    records.append({\n",
    "        \"title\": node['title'],\n",
    "        \"created_at\": node['createdAt'],\n",
    "        \"author\": node['author']['login'] if node['author'] else None\n",
    "    })\n",
    "\n",
    "# Create DataFrame\n",
    "df = pd.DataFrame(records)\n",
    "\n",
    "# Display first few rows\n",
    "print(df.head())\n"
